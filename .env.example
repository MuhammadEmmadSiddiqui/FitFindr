# Environment Configuration for FitFindr

# API Keys (comma-separated for multiple clients)
GROQ_API_KEYS=your_api_key_1,your_api_key_2,your_api_key_3

# Application Settings
DEBUG=False
APP_NAME=FitFindr
APP_VERSION=1.0.0

# Database
DATABASE_URL=sqlite:///./data/fitfindr.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/fitfindr

# Model Configuration
BERT_MODEL=bert-base-uncased
LLM_MODEL=llama3-8b-8192
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024
LLM_TOP_P=0.65

# Server Configuration
STREAMLIT_PORT=8501
API_PORT=8000
API_HOST=0.0.0.0

# Logging
LOG_LEVEL=INFO
LOG_FILE=fitfindr.log
